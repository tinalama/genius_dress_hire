# Optional: override YAML / defaults for local secrets (see config/default.yml).
# This file is loaded by dotenv BEFORE node-config merges with
# config/custom-environment-variables.json.
#
# You can run without a .env file if config/default.yml is enough.

NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=genius_dress_hire
DB_SYNCHRONIZE=false
DB_LOGGING=false

JWT_SECRET=change-me-min-16-chars!!
JWT_EXPIRES_IN=7d

API_PREFIX=api
SWAGGER_ENABLED=true
